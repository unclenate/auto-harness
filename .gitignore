# Claude Code runtime state and generated skill links/adapters. Canonical skills
# live under platform/skills/ and should be projected into tool-local folders,
# not maintained there as independent copies.
.claude/
.remember/

# Sample-project example .claude/ directories are reference implementations
# that ship checked-in (not consumer runtime state). Negate the .claude/ ignore
# above for paths under platform/examples/sample-projects/*/.claude/.
!platform/examples/sample-projects/*/.claude/
!platform/examples/sample-projects/*/.claude/**
